[PrefixDeclaration]
ontomofs_vkg:       https://www.theworldavatar.com/kg/ontomofs_vkg/
rdf:                http://www.w3.org/1999/02/22-rdf-syntax-ns#
owl:                http://www.w3.org/2002/07/owl#
xsd:                http://www.w3.org/2001/XMLSchema#

[MappingDeclaration] @collection [[
mappingId       Provenance
target      ontomofs_vkg:provenance_{number} a ontomofs_vkg:Provenance;
                    ontomofs_vkg:hasReferenceDOI "{DOI}"^^xsd:string ; 
                    ontomofs_vkg:hasYearPublished "{Year}"^^xsd:string.
source      SELECT number, "DOI", "Year"
            FROM "CR_data_CSD_modified_20250227"

mappingId       Topology
target      ontomofs_vkg:Topology_{number} a ontomofs_vkg:Topology;
                    ontomofs_vkg:hasRCSRSym "{topology(AllNodes)}"^^xsd:string;
                    ontomofs_vkg:hasCatenation "{catenation}"^^xsd:integer ;
                    ontomofs_vkg:hasDimension "{dimension_by_topo}"^^xsd:integer.
source      SELECT number, "topology(AllNodes)", "catenation", "dimension_by_topo"
            FROM "CR_data_CSD_modified_20250227"

mappingId       PoreDiameter
target      ontomofs_vkg:PoreDiameter_{number} a ontomofs_vkg:PoreDiameter;
                    ontomofs_vkg:hasPLD "{PLD (Å)}"^^xsd:float;
                    ontomofs_vkg:hasLCD "{LCD (Å)}"^^xsd:float;
                    ontomofs_vkg:hasLFPD "{LFPD (Å)}"^^xsd:float.
source      SELECT number, "PLD (Å)", "LCD (Å)", "LFPD (Å)"
            FROM "CR_data_CSD_modified_20250227"

mappingId       SurfaceArea
target      ontomofs_vkg:SurfaceArea_{number} a ontomofs_vkg:SurfaceArea;
                    ontomofs_vkg:hasASA "{ASA (A2)}"^^xsd:float;
                    ontomofs_vkg:hasNASA "{NASA (A2)}"^^xsd:float ;
                    ontomofs_vkg:hasGSA "{ASA (m2/g)}"^^xsd:float;
                    ontomofs_vkg:hasNGSA "{NASA (m2/g)}"^^xsd:float;
                    ontomofs_vkg:hasVSA "{ASA (m2/cm3)}"^^xsd:float;
                    ontomofs_vkg:hasNVSA "{NASA (m2/cm3)}"^^xsd:float.
source      SELECT number, "ASA (A2)", "ASA (m2/cm3)", "ASA (m2/g)" , "NASA (A2)" , "NASA (m2/cm3)", "NASA (m2/g)"
            FROM "CR_data_CSD_modified_20250227"

mappingId       PoreVolume
target      ontomofs_vkg:PoreVolume_{number} a ontomofs_vkg:PoreVolume;
                    ontomofs_vkg:hasPV "{PV (A3)}"^^xsd:float;
                    ontomofs_vkg:hasNPV "{NAV (A3)}"^^xsd:float;
                    ontomofs_vkg:hasGPV "{PV (cm3/g)}"^^xsd:float;
                    ontomofs_vkg:hasNGPV "{NPV (cm3/g)}"^^xsd:float;
                    ontomofs_vkg:hasVF "{VF}"^^xsd:float;
                    ontomofs_vkg:hasNVF "{NAV_VF}"^^xsd:float.
source      SELECT number, "PV (A3)","VF","PV (cm3/g)","NAV (A3)","NAV_VF","NPV (cm3/g)"
            FROM "CR_data_CSD_modified_20250227"

mappingId       CrystalStructure
target      ontomofs_vkg:CrystalStructure_{number} a ontomofs_vkg:CrystalStructure;
                    ontomofs_vkg:hasSpaceGroupNumber "{number_spacegroup}"^^xsd:integer;
                    ontomofs_vkg:hasDensity "{Density (g/cm3)}"^^xsd:float.
source      SELECT number, "number_spacegroup", "Density (g/cm3)"
            FROM "CR_data_CSD_modified_20250227"

mappingId       Stability
target      ontomofs_vkg:Stability_{number} a ontomofs_vkg:Stability;
                    ontomofs_vkg:hasThermalStability "{Thermal_stability (℃)}"^^xsd:float;
                    ontomofs_vkg:hasSolventStability "{Solvent_stability}"^^xsd:float;
                    ontomofs_vkg:hasWaterStability "{Water_stability}"^^xsd:float;
                    ontomofs_vkg:hasKHwater "{KH_Classes}"^^xsd:string.
source      SELECT number, "Thermal_stability (℃)", "Solvent_stability", "Water_stability", "KH_Classes"
            FROM "CR_data_CSD_modified_20250227"

mappingId       HeatCapacity
target      ontomofs_vkg:_{number}_300 a ontomofs_vkg:HeatCapacity;
                    ontomofs_vkg:hasNumericalValue "{Heat_capacity@300K (J/g/K)}"^^xsd:float ;
                    ontomofs_vkg:hasTemperature "300"^^xsd:float ;
                    ontomofs_vkg:hasUncertainty "{std @ 300 K (J/g/K)}"^^xsd:float.
            ontomofs_vkg:_{number}_350 a ontomofs_vkg:HeatCapacity;
                    ontomofs_vkg:hasNumericalValue "{Heat_capacity@350K (J/g/K)}"^^xsd:float ;
                    ontomofs_vkg:hasTemperature "350"^^xsd:float ;
                    ontomofs_vkg:hasUncertainty "{std @ 350 K (J/g/K)}"^^xsd:float.
            ontomofs_vkg:_{number}_400 a ontomofs_vkg:HeatCapacity;
                    ontomofs_vkg:hasNumericalValue "{Heat_capacity@400K (J/g/K)}"^^xsd:float ;
                    ontomofs_vkg:hasTemperature "400"^^xsd:float ;
                    ontomofs_vkg:hasUncertainty "{std @ 400 K (J/g/K)}"^^xsd:float.
source      SELECT number, "Heat_capacity@300K (J/g/K)", "std @ 300 K (J/g/K)", "Heat_capacity@350K (J/g/K)", "std @ 350 K (J/g/K)", "Heat_capacity@400K (J/g/K)", "std @ 400 K (J/g/K)"
            FROM "CR_data_CSD_modified_20250227"

mappingId       Identifier
target      ontomofs_vkg:Identifiers_{number} a ontomofs_vkg:Identifier;
                    ontomofs_vkg:hasmofid_v1 "{mofid-v1}"^^xsd:string;
                    ontomofs_vkg:hasmofid_v2 "{mofid-v2}"^^xsd:string;
                    ontomofs_vkg:hascsd_refcode "{refcode}"^^xsd:string;
                    ontomofs_vkg:hasdb_id "{coreid}"^^xsd:string;
                    ontomofs_vkg:hasNames "{name}"^^xsd:string.
source      SELECT number, "coreid",	"refcode",	"name", "mofid-v1", "mofid-v2"
            FROM "CR_data_CSD_modified_20250227"

mappingId       ChemicalIdentity
target      ontomofs_vkg:ChemicalIdentity_{number} a ontomofs_vkg:ChemicalIdentity;
                    ontomofs_vkg:hasMetal "{Metal Types}"^^xsd:string;
                    ontomofs_vkg:hasOpenMetalSite "{Has OMS}"^^xsd:string;
                    ontomofs_vkg:hasMass "{average_atomic_mass}"^^xsd:float.
source      SELECT number, "Metal Types","Has OMS", "average_atomic_mass"
            FROM "CR_data_CSD_modified_20250227"

mappingId       MetalOrganicFramework
target      ontomofs_vkg:mof_{number} a ontomofs_vkg:MetalOrganicFramework;
                    ontomofs_vkg:hasIdentifiers ontomofs_vkg:Identifiers_{number};
                    ontomofs_vkg:hasTopology ontomofs_vkg:Topology_{number};
                    ontomofs_vkg:hasSourcedb "CoRE MOF 2025"^^xsd:string;
                    ontomofs_vkg:hasProvenance ontomofs_vkg:provenance_{number};
                    ontomofs_vkg:hasPoreDiameter ontomofs_vkg:PoreDiameter_{number};
                    ontomofs_vkg:hasSurfaceArea ontomofs_vkg:SurfaceArea_{number};
                    ontomofs_vkg:hasPoreVolume ontomofs_vkg:PoreVolume_{number};
                    ontomofs_vkg:isExperimental "true"^^xsd:boolean;
                    ontomofs_vkg:isHypothetical "false"^^xsd:boolean;
                    ontomofs_vkg:hasStability ontomofs_vkg:Stability_{number};
                    ontomofs_vkg:hasHeatCapacity ontomofs_vkg:HeatCapacity_{number}_300;
                    ontomofs_vkg:hasHeatCapacity ontomofs_vkg:HeatCapacity_{number}_350;
                    ontomofs_vkg:hasHeatCapacity ontomofs_vkg:HeatCapacity_{number}_400;
                    ontomofs_vkg:hasChemicalIdentity ontomofs_vkg:ChemicalIdentity_{number};
                    ontomofs_vkg:hasCrystalStructure ontomofs_vkg:CrystalStructure_{number}.
source      SELECT number
            FROM "CR_data_CSD_modified_20250227"

]]